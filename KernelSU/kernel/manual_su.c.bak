#include <linux/string.h>
#include <linux/uaccess.h>
#include <linux/printk.h>
#include <linux/cred.h>
#include <linux/fs.h>
#include <linux/file.h>
#include <linux/mm.h>
#include <linux/random.h>
#include <linux/slab.h>
#include <linux/binfmts.h>
#include <linux/rcupdate.h>
#include <linux/pid.h>

#include "manual_su.h"
#include "ksu.h"
#include "allowlist.h"
#include "manager.h"
#include "app_profile.h"

static bool current_verified = false;
static void ksu_cleanup_expired_tokens(void);
static bool is_current_verified(void);
static void add_pending_root(uid_t uid);

static struct pending_uid pending_uids[MAX_PENDING];
static int pending_cnt;
static struct ksu_token_entry auth_tokens[MAX_TOKENS];
static int token_count;
static DEFINE_SPINLOCK(token_lock);

/* ======================= ENV TOKEN ======================= */

static char *get_token_from_envp(void)
{
	struct mm_struct *mm;
	char *envp_start, *envp_end;
	char *env_ptr, *token = NULL;
	unsigned long env_len;
	char *env_copy = NULL;

	mm = get_task_mm(current);
	if (!mm)
		return NULL;

	if (mmap_read_lock_killable(mm)) {
		mmput(mm);
		return NULL;
	}

	envp_start = (char *)mm->env_start;
	envp_end   = (char *)mm->env_end;
	env_len    = envp_end - envp_start;

	if (env_len <= 0 || env_len > PAGE_SIZE * 32) {
		mmap_read_unlock(mm);
		mmput(mm);
		return NULL;
	}

	env_copy = kzalloc(env_len + 1, GFP_KERNEL);
	if (!env_copy) {
		mmap_read_unlock(mm);
		mmput(mm);
		return NULL;
	}

	if (copy_from_user(env_copy, envp_start, env_len)) {
		kfree(env_copy);
		mmap_read_unlock(mm);
		mmput(mm);
		return NULL;
	}

	mmap_read_unlock(mm);
	mmput(mm);

	env_copy[env_len] = '\0';
	env_ptr = env_copy;

	while (env_ptr < env_copy + env_len) {
		if (!strncmp(env_ptr, KSU_TOKEN_ENV_NAME "=",
			     strlen(KSU_TOKEN_ENV_NAME) + 1)) {

			char *token_start =
				env_ptr + strlen(KSU_TOKEN_ENV_NAME) + 1;
			char *token_end = strchr(token_start, '\0');

			if (token_end &&
			    (token_end - token_start) == KSU_TOKEN_LENGTH) {

				token = kzalloc(KSU_TOKEN_LENGTH + 1,
						GFP_KERNEL);
				if (token) {
					memcpy(token, token_start,
					       KSU_TOKEN_LENGTH);
					token[KSU_TOKEN_LENGTH] = '\0';
					pr_info("manual_su: auth token found\n");
				}
			}
			break;
		}

		env_ptr += strlen(env_ptr) + 1;
	}

	kfree(env_copy);
	return token;
}

/* ======================= TOKEN SYSTEM ======================= */

static char *ksu_generate_auth_token(void)
{
	static char token_buffer[KSU_TOKEN_LENGTH + 1];
	unsigned long flags;
	int i;

	ksu_cleanup_expired_tokens();

	spin_lock_irqsave(&token_lock, flags);

	if (token_count >= MAX_TOKENS) {
		memmove(&auth_tokens[0],
			&auth_tokens[1],
			sizeof(auth_tokens[0]) * (MAX_TOKENS - 1));
		token_count = MAX_TOKENS - 1;
	}

	for (i = 0; i < KSU_TOKEN_LENGTH; i++) {
		u8 rand_byte;
		get_random_bytes(&rand_byte, 1);

		switch (rand_byte % 3) {
		case 0:
			token_buffer[i] = 'A' + (rand_byte % 26);
			break;
		case 1:
			token_buffer[i] = 'a' + (rand_byte % 26);
			break;
		default:
			token_buffer[i] = '0' + (rand_byte % 10);
		}
	}

	token_buffer[KSU_TOKEN_LENGTH] = '\0';

	strscpy(auth_tokens[token_count].token,
		token_buffer,
		KSU_TOKEN_LENGTH + 1);

	auth_tokens[token_count].expire_time =
		jiffies + KSU_TOKEN_EXPIRE_TIME * HZ;

	auth_tokens[token_count].used = false;
	token_count++;

	spin_unlock_irqrestore(&token_lock, flags);

	return token_buffer;
}

static bool ksu_verify_auth_token(const char *token)
{
	unsigned long flags;
	bool valid = false;
	int i;

	if (!token || strlen(token) != KSU_TOKEN_LENGTH)
		return false;

	spin_lock_irqsave(&token_lock, flags);

	for (i = 0; i < token_count; i++) {
		if (!auth_tokens[i].used &&
		    time_before(jiffies, auth_tokens[i].expire_time) &&
		    !strcmp(auth_tokens[i].token, token)) {

			auth_tokens[i].used = true;
			valid = true;
			break;
		}
	}

	spin_unlock_irqrestore(&token_lock, flags);
	return valid;
}

static void ksu_cleanup_expired_tokens(void)
{
	unsigned long flags;
	int i;

	spin_lock_irqsave(&token_lock, flags);

	for (i = 0; i < token_count;) {
		if (time_after(jiffies, auth_tokens[i].expire_time) ||
		    auth_tokens[i].used) {

			memmove(&auth_tokens[i],
				&auth_tokens[i + 1],
				sizeof(auth_tokens[0]) *
				(token_count - i - 1));

			token_count--;
		} else {
			i++;
		}
	}

	spin_unlock_irqrestore(&token_lock, flags);
}

/* ======================= HANDLERS ======================= */

static int handle_token_generation(struct manual_su_request *request)
{
	char *new_token;

	if (current_uid().val > 2000)
		return -EPERM;

	new_token = ksu_generate_auth_token();
	if (!new_token)
		return -ENOMEM;

	strscpy(request->token_buffer,
		new_token,
		KSU_TOKEN_LENGTH + 1);

	return 0;
}

static int handle_escalation_request(struct manual_su_request *request)
{
	struct task_struct *tsk;
	char *env_token;
	bool token_valid;

	rcu_read_lock();
	tsk = pid_task(find_vpid(request->target_pid), PIDTYPE_PID);
	if (!tsk || ksu_task_is_dead(tsk)) {
		rcu_read_unlock();
		return -ESRCH;
	}
	rcu_read_unlock();

	if (current_uid().val == 0 ||
	    is_manager() ||
	    ksu_is_allow_uid_for_current(current_uid().val))
		goto allowed;

	env_token = get_token_from_envp();
	if (!env_token)
		return -EACCES;

	token_valid = ksu_verify_auth_token(env_token);
	kfree(env_token);

	if (!token_valid)
		return -EACCES;

allowed:
	current_verified = true;
	escape_to_root_for_cmd_su(request->target_uid,
				  request->target_pid);
	return 0;
}

static int handle_add_pending_request(struct manual_su_request *request)
{
	if (!is_current_verified())
		return -EPERM;

	add_pending_root(request->target_uid);
	current_verified = false;
	return 0;
}

/* ======================= MAIN ENTRY ======================= */

int ksu_handle_manual_su_request(int option,
				 struct manual_su_request *request)
{
	if (!request)
		return -EINVAL;

	switch (option) {
	case MANUAL_SU_OP_GENERATE_TOKEN:
		return handle_token_generation(request);
	case MANUAL_SU_OP_ESCALATE:
		return handle_escalation_request(request);
	case MANUAL_SU_OP_ADD_PENDING:
		return handle_add_pending_request(request);
	default:
		return -EINVAL;
	}
}

/* ======================= PENDING ROOT ======================= */

static bool is_current_verified(void)
{
	return current_verified;
}

bool is_pending_root(uid_t uid)
{
	int i;

	for (i = 0; i < pending_cnt; i++) {
		if (pending_uids[i].uid == uid) {
			pending_uids[i].use_count++;
			pending_uids[i].remove_calls++;
			return true;
		}
	}
	return false;
}

void remove_pending_root(uid_t uid)
{
	int i;

	for (i = 0; i < pending_cnt; i++) {
		if (pending_uids[i].uid == uid) {

			pending_uids[i].remove_calls++;

			if (pending_uids[i].remove_calls >=
			    REMOVE_DELAY_CALLS) {

				pending_uids[i] =
					pending_uids[--pending_cnt];

				ksu_temp_revoke_root_once(uid);
			}
			return;
		}
	}
}

static void add_pending_root(uid_t uid)
{
	int i;

	if (pending_cnt >= MAX_PENDING)
		return;

	for (i = 0; i < pending_cnt; i++) {
		if (pending_uids[i].uid == uid) {
			pending_uids[i].use_count = 0;
			pending_uids[i].remove_calls = 0;
			return;
		}
	}

	pending_uids[pending_cnt++] =
		(struct pending_uid){ uid, 0, 0 };

	ksu_temp_grant_root_once(uid);
}

void ksu_try_escalate_for_uid(uid_t uid)
{
	if (!is_pending_root(uid))
		return;

	remove_pending_root(uid);
}